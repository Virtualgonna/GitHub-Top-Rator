{
  "name": "github-top-radar",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "launcher": "node scripts/launcher-server.cjs",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:build": "tsc && vite build && electron-builder --win --config electron-builder.cjs"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12",
    "playwright": "^1.61.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
